{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guardrail by JAMARQ",
  "version": "0.1.0",
  "identifier": "com.jamarq.guardrail",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Guardrail by JAMARQ",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 780
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
